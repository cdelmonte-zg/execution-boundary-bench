# Copy to terraform.tfvars and fill in your values

project_id          = "my-gcp-project"
region              = "europe-west1"
zone                = "europe-west1-b"
machine_type        = "n2-standard-4"
node_count          = 2
ssh_public_key_path = "~/.ssh/id_rsa.pub"
ssh_user            = "bench"
k8s_version         = "1.29"
